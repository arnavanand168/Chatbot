{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build with g++-15",
        "type": "shell",
        "command": "/opt/homebrew/bin/g++-15",    
        "args": [
          "-std=gnu++17",                        
          "-Wall",
          "-O2",
          "${file}",                      
          "-o",
          "${fileDirname}/${fileBasenameNoExtension}"
        ],
        "options": {
          "cwd": "${fileDirname}"
        },
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": ["$gcc"],
        "detail": "Build using Homebrew GCC g++-15"
      }
    ]
  }
  